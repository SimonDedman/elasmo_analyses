    "imp_direction": {
      "description": "Overall direction of reported impact (positive / negative / mixed / not stated).",
      "method": "Sentiment-cue counting across the full PDF text.",
      "positive_cues": [
        "increase[sd]?",
        "recover\\w*",
        "improve\\w*",
        "growth",
        "positive",
        "restor\\w+",
        "enhance\\w*",
        "higher",
        "gain",
        "benefit",
        "proliferat\\w*"
      ],
      "negative_cues": [
        "decline[sd]?",
        "decrease[sd]?",
        "loss",
        "reduce[sd]?",
        "reduction",
        "deplet\\w+",
        "degrad\\w+",
        "lower",
        "negative",
        "threat",
        "endanger",
        "extinct",
        "collapse[sd]?",
        "diminish\\w*",
        "worsen\\w*"
      ],
      "logic": [
        "neg > 2 × pos → 'negative'",
        "pos > 2 × neg → 'positive'",
        "both present, neither dominant → 'mixed'",
        "only negative cues → 'negative'",
        "only positive cues → 'positive'",
        "neither present → 'not stated'"
      ],
      "source": "scripts/extract_schema_columns.py → assess_impact_direction()"
    },
    "imp_quantified": {
      "description": "Whether the paper provides any quantitative impact measure.",
      "method": "Regex scan of full PDF text for numeric / statistical markers.",
      "patterns": [
        "N.N% (percentages)",
        "decimal numbers (e.g. 0.42)",
        "CI / confidence interval with : or =",
        "p < 0.NN / p = 0.NN (p-values)",
        "± N (plus-minus notation)"
      ],
      "logic": [
        "True if any pattern matches anywhere in the PDF text; False otherwise."
      ],
      "source": "scripts/extract_schema_columns.py → assess_impact_quantified()"
    },
    "imp_confidence": {
      "description": "Heuristic confidence score for the impact-section extraction.",
      "method": "Derived from the number of imp_ topic columns that triggered and the presence of imp_quantified evidence.",
      "logic": [
        "Currently a triggered-flag set when any imp_ topic column fires; will be replaced with a numeric 0–1 score in a future pass.",
        "Low confidence → impact discussed in passing; high confidence → impact is a primary finding."
      ],
      "source": "scripts/extract_schema_columns.py"
    },
    "imp_is_bycatch": {
      "description": "Whether the paper treats elasmobranchs as bycatch rather than as the directly targeted catch.",
      "method": "Joint check of pr_bycatch flag and target-species extraction from gear context.",
      "logic": [
        "True  → pr_bycatch = 1 AND a non-elasmobranch target species (e.g. 'tuna fishery') is extracted.",
        "False → pr_bycatch = 0.",
        "None  → pr_bycatch = 1 but target species unclear or is itself an elasmobranch."
      ],
      "source": "scripts/extract_schema_columns.py → bycatch_direction()"
    }
  },
