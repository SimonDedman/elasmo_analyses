@article{lennon_going_2021,
	title = {Going deeper, darker and further: {Observations} charting an egg nursery, a range and depth extension for the deep-sea spiny tailed skate \textit{{Bathyraja} spinicauda,} first records from the {Mid} {Atlantic} {Ridge}},
	volume = {175},
