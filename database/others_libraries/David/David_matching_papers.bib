	note = {Number: 1},
	keywords = {Balearic Islands},
	pages = {87--96},
	file = {Full Text PDF:C\:\\Users\\david\\Zotero\\storage\\3NN66GCB\\Guijarro et al. - 2012 - Inter- and intra-annual trends and status indicato.pdf:application/pdf},
