@article{finucci_first_2024,
	title = {First observation of a skate egg case nursery in the {Ross} {Sea}},
	volume = {104},
	issn = {1095-8649},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/jfb.15688},
	doi = {10.1111/jfb.15688},
	abstract = {Areas of importance to Southern Ocean skates are poorly defined. Here, we identify a deepwater skate egg case nursery in a discrete location at 460 m depth off Cape Adare in the Southern Ocean. This is the first confirmed observation of a skate nursery area in the Ross Sea and only the second observation for the Southern Ocean. The morphology and size of the egg cases were consistent with the genus Bathyraja and most likely belong to the Bathyraja sp. (cf. eatonii). The nursery occurs within the “no take” General Protection Zone of the Ross Sea region marine protected area, where commercial fishing is prohibited.},
	language = {en},
