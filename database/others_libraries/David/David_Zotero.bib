@article{hindell_tracking_2020,
	title = {Tracking of marine predators to protect {Southern} {Ocean} ecosystems},
	volume = {580},
	copyright = {2020 The Author(s), under exclusive licence to Springer Nature Limited},
	issn = {1476-4687},
