	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/mms.70070},
	keywords = {beaked whale, dive cycle, echolocation, echolocation depth, foraging dive duration, maximum dive depth, Mesoplodon densirostris, Ziphius cavirostris},
