@article{coll_biodiversity_2010,
	title = {The {Biodiversity} of the {Mediterranean} {Sea}: {Estimates}, {Patterns}, and {Threats}},
	volume = {5},
	issn = {1932-6203},
	shorttitle = {The {Biodiversity} of the {Mediterranean} {Sea}},
	url = {https://journals.plos.org/plosone/article?id=10.1371/journal.pone.0011842},
	doi = {10.1371/journal.pone.0011842},
	abstract = {The Mediterranean Sea is a marine biodiversity hot spot. Here we combined an extensive literature analysis with expert opinions to update publicly available estimates of major taxa in this marine ecosystem and to revise and update several species lists. We also assessed overall spatial and temporal patterns of species diversity and identified major changes and threats. Our results listed approximately 17,000 marine species occurring in the Mediterranean Sea. However, our estimates of marine diversity are still incomplete as yet—undescribed species will be added in the future. Diversity for microbes is substantially underestimated, and the deep-sea areas and portions of the southern and eastern region are still poorly known. In addition, the invasion of alien species is a crucial factor that will continue to change the biodiversity of the Mediterranean, mainly in its eastern basin that can spread rapidly northwards and westwards due to the warming of the Mediterranean Sea. Spatial patterns showed a general decrease in biodiversity from northwestern to southeastern regions following a gradient of production, with some exceptions and caution due to gaps in our knowledge of the biota along the southern and eastern rims. Biodiversity was also generally higher in coastal areas and continental shelves, and decreases with depth. Temporal trends indicated that overexploitation and habitat loss have been the main human drivers of historical changes in biodiversity. At present, habitat loss and degradation, followed by fishing impacts, pollution, climate change, eutrophication, and the establishment of alien species are the most important threats and affect the greatest number of taxonomic groups. All these impacts are expected to grow in importance in the future, especially climate change and habitat degradation. The spatial identification of hot spots highlighted the ecological importance of most of the western Mediterranean shelves (and in particular, the Strait of Gibraltar and the adjacent Alboran Sea), western African coast, the Adriatic, and the Aegean Sea, which show high concentrations of endangered, threatened, or vulnerable species. The Levantine Basin, severely impacted by the invasion of species, is endangered as well. This abstract has been translated to other languages (File S1).},
	language = {en},
	number = {8},
	urldate = {2025-03-05},
	journal = {PLOS ONE},
	publisher = {Public Library of Science},
	author = {Coll, Marta and Piroddi, Chiara and Steenbeek, Jeroen and Kaschner, Kristin and Lasram, Frida Ben Rais and Aguzzi, Jacopo and Ballesteros, Enric and Bianchi, Carlo Nike and Corbera, Jordi and Dailianis, Thanos and Danovaro, Roberto and Estrada, Marta and Froglia, Carlo and Galil, Bella S. and Gasol, Josep M. and Gertwagen, Ruthy and Gil, João and Guilhaumon, François and Kesner-Reyes, Kathleen and Kitsos, Miltiadis-Spyridon and Koukouras, Athanasios and Lampadariou, Nikolaos and Laxamana, Elijah and Cuadra, Carlos M. López-Fé de la and Lotze, Heike K. and Martin, Daniel and Mouillot, David and Oro, Daniel and Raicevich, Saša and Rius-Barile, Josephine and Saiz-Salinas, Jose Ignacio and Vicente, Carles San and Somot, Samuel and Templado, José and Turon, Xavier and Vafidis, Dimitris and Villanueva, Roger and Voultsiadou, Eleni},
	month = aug,
	year = {2010},
	keywords = {Biodiversity, Invasive species, Invertebrates, Marine biology, Marine fish, Mediterranean Sea, Species diversity, Taxonomy},
	pages = {e11842},
	file = {Full Text PDF:C\:\\Users\\david\\Zotero\\storage\\PE4S2INT\\Coll et al. - 2010 - The Biodiversity of the Mediterranean Sea Estimat.pdf:application/pdf},
}

@article{jukic-peladic_long-term_2001,
	title = {Long-term changes in demersal resources of the {Adriatic} {Sea}: comparison between trawl surveys carried out in 1948 and 1998},
	volume = {53},
	issn = {0165-7836},
	shorttitle = {Long-term changes in demersal resources of the {Adriatic} {Sea}},
	url = {https://www.sciencedirect.com/science/article/pii/S0165783600002320},
	doi = {10.1016/S0165-7836(00)00232-0},
	abstract = {Trawl surveys carried out in the Adriatic Sea in 1948 and 1998 provided information on the changes that occurred in the composition and distribution of demersal fish resources over the 50 years period. The main change was the decrease of elasmobranchs diversity and frequency, mostly referring to the Hypotremata group. Life history parameters appeared to be determining factors, since small sized species such as the smallspotted catshark (S. canicula) or the brown ray (R. miraletus) were frequently collected in both surveys, while bigger shark species and most other rays disappeared or were rarely found during the 1998 survey. Regarding bony fishes, common species were collected with similar frequency in both surveys; some fishery target species (e.g. the hake) have similar percentage values (biomass) in both surveys, while others (the silver scabbardfish) have increased values, and some (mainly small sized species such as red mullet) replace elasmobranchs at the top of the catches. Despite the low number of observations (two surveys only) and some sampling differences, the data provide an interesting long-term comparison.},
	number = {1},
	urldate = {2025-03-05},
	journal = {Fisheries Research},
	author = {Jukic-Peladic, S and Vrgoc, N and Krstulovic-Sifner, S and Piccinetti, C and Piccinetti-Manfrin, G and Marano, G and Ungaro, N},
	month = sep,
	year = {2001},
	keywords = {Elasmobranchs, Adriatic Sea, Central Mediterranean, Demersal resources, Long-term changes},
	pages = {95--104},
	file = {ScienceDirect Snapshot:C\:\\Users\\david\\Zotero\\storage\\TVIIJ3FE\\S0165783600002320.html:text/html},
}

