@article{adams_sharks_2018,
	title = {Sharks, rays and abortion: {The} prevalence of capture-induced parturition in elasmobranchs},
	volume = {217},
	issn = {0006-3207},
	shorttitle = {Sharks, rays and abortion},
	url = {https://www.sciencedirect.com/science/article/pii/S0006320717303634},
	doi = {10.1016/j.biocon.2017.10.010},
	abstract = {The direct impacts of fishing on chondrichthyans (sharks, rays and chimeras) are well established. Here we review a largely unreported, often misinterpreted and poorly understood indirect impact of fishing on these animals — capture-induced parturition (either premature birth or abortion). Although direct mortality of discarded sharks and rays has been estimated, the prevalence of abortion/premature birth and subsequent generational mortality remains largely unstudied. We synthesize a diffuse body of literature to reveal that a conservative estimate of {\textgreater}12\% of live bearing elasmobranchs (n=88 species) show capture-induced parturition. For those species with adequate data, we estimate capture-induced parturition events ranging from 2 to 85\% of pregnant females (average 24\%). To date, capture-induced parturition has only been observed in live-bearing species. We compile data on threat-levels, method of capture, reproductive mode and gestation extent of premature/aborted embryos. We also utilise social media to identify 41 social-media links depicting a capture-induced parturition event which provide supplementary visual evidence for the phenomenon. The mortality of embryos will have implications for elasmobranch populations, and there are limited options to deal with this problem. This review is the first to synthesize available data on capture-induced parturition in sharks and rays, and highlights an important ethical and management issue for fishers and managers deserving of much greater attention.},
	urldate = {2025-04-05},
	journal = {Biological Conservation},
	author = {Adams, Kye R. and Fetterplace, Lachlan C. and Davis, Andrew R. and Taylor, Matthew D. and Knott, Nathan A.},
	month = jan,
	year = {2018},
	pages = {11--27},
	file = {Versión enviada:C\:\\Users\\david\\Zotero\\storage\\GQ27XA2G\\Adams et al. - 2018 - Sharks, rays and abortion The prevalence of captu.pdf:application/pdf},
}

@article{wosnick_behavioral_2023,
	title = {Behavioral and visual stress-induced proxies in elasmobranchs},
	volume = {33},
	issn = {1573-5184},
	url = {https://doi.org/10.1007/s11160-023-09757-8},
	doi = {10.1007/s11160-023-09757-8},
	abstract = {Understanding how elasmobranchs respond to stressors is imperative so that effective measures to reduce mortality be employed, whether in commercially captured animals or sharks and rays maintained in human care. Currently, reflex action mortality predictors (RAMPs) are the most reliable proxies to indicate an animal's condition state, commonly employed for both teleost and elasmobranchs. As our understanding of mortality predictors is evolving, is it necessary that traditional indicators be constantly reviewed and new proxies proposed, in order to improve the tools available for the best possible evaluation of a stressed individual. In this context, this review aimed to compile data on behavioral and visual proxies, along with the proposition of new proxies to guide professionals and assist them in identifying signs associated with alarming situations that might potentially result in the death of highly stressed individuals or sub-lethal effects at population level (migration, reproduction) that may seriously compromise the success of release measures.},
	language = {en},
	number = {1},
	urldate = {2025-04-05},
	journal = {Reviews in Fish Biology and Fisheries},
	author = {Wosnick, Natascha and Leite, Renata Daldin and Balanin, Samuel and Chaves, Ana Paula and de Senna Gastal, Eduardo Rufino and Hauser-Davis, Rachel Ann and Giareta, Eloísa Pinheiro},
	month = mar,
	year = {2023},
	keywords = {Sharks, Rays, Stress, Fishing, Reflex action mortality predictors},
	pages = {175--199},
	file = {Full Text PDF:C\:\\Users\\david\\Zotero\\storage\\TL472KCK\\Wosnick et al. - 2023 - Behavioral and visual stress-induced proxies in el.pdf:application/pdf},
}

