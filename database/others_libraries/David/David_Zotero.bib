@article{fernandezcorredor_environmental_2025,
	title = {Environmental and human factors shape the trophic ecology of a widespread marine predator},
	volume = {94},
	issn = {0021-8790, 1365-2656},
	url = {https://besjournals.onlinelibrary.wiley.com/doi/10.1111/1365-2656.70087},
	doi = {10.1111/1365-2656.70087},
	abstract = {Abstract
            
              
                
                  Integrative approaches that investigate trophic ecology drivers provide knowledge to explore and predict changes in food‐web dynamics under contrasting scenarios of global change. However, there are few studies that analyse the relationship between environmental factors and trophic interactions and that additionally consider other human stressors such as fisheries.
                
                
                  
                    Here, we use Bayesian Stable isotope mixing models to study the trophic ecology of a widespread pelagic predatory fish, the swordfish (
                    Xiphias gladius
                    ), in the western Mediterranean Sea and the adjacent Atlantic waters. We explore the relationships between dietary estimates and biological, environmental and anthropogenic drivers using generalized additive models (GAMs). GAMs are used to develop spatial predictions of present prey consumption and, as a prospective exercise, to project changes in prey consumption under different future climate change scenarios.
                  
                
                
                  
                    Overall, we found that swordfish diet varied as a response to changing environmental conditions, particularly to varying sea surface temperature (SST), mixed layer depth (MLD) and chlorophyll‐
                    a
                    concentration (Chl); and to fishing pressure. Fish consumption was related to SST and MLD. Squid consumption was related to SST, with the greatest contributions observed in swordfish of intermediate lengths. Squid had a higher contribution to swordfish diet around the Canary Islands and the western Mediterranean Sea, while gelatinous organisms were more consumed around the Gulf of Cádiz. The consumption of gelatinous organisms was higher in smaller swordfish and in areas with lower productivity.
                  
                
                
                  Our prospective exercise suggested different diet alterations under contrasting future global change scenarios. For the first time, we provide quantitative evidence of how large‐scale, spatial–temporal patterns in fishing pressure and environmental conditions can shape the diet of swordfish. Our study presents useful results to assess the diet of this predator and highlight how incorporating trophic interactions into projections can improve our understanding of future distributions.
                
              
            
          , 
            Resumen
            
              
                
                  Estudiar la ecología trófica y los factores que la influyen de manera integrada permite explorar y predecir cambios en la dinámica de las redes tróficas bajo diferentes escenarios de cambio global. Sin embargo, existen pocos estudios que analicen la relación entre los factores ambientales y las interacciones tróficas, y que además consideren otros factores de estrés humano, como la pesca.
                
                
                  En este estudio, utilizamos modelos bayesianos de mezcla de isótopos estables para estudiar la ecología trófica de un depredador pelágico ampliamente distribuido, el pez espada (Xiphias gladius), en el Mediterráneo occidental y las aguas atlánticas adyacentes. Exploramos las relaciones entre su dieta y los factores biológicos, ambientales y antropogénicos mediante modelos aditivos generalizados (GAM). Estos modelos son utilizados para desarrollar predicciones espaciales del consumo actual de presas y, como ejercicio prospectivo, para proyectar cambios en el consumo de presas bajo diferentes escenarios futuros de cambio climático.
                
                
                  En general, observamos que la dieta del pez espada varió en respuesta a las condiciones ambientales, en particular a la variación de la temperatura superficial del mar (SST), la profundidad de la capa de mezcla (MLD) y la concentración de clorofila; así como a la presión pesquera. El consumo de peces se relacionó con la SST y la MLD. El consumo de calamares se relacionó con la SST, observándose las mayores contribuciones en los individuos de tamaño intermedio. Los calamares contribuyeron en mayor medida a la dieta del pez espada en las Islas Canarias y el Mediterráneo occidental, mientras que los organismos gelatinosos se consumieron más en el Golfo de Cádiz. El consumo de organismos gelatinosos fue mayor en los peces espada más pequeños y en áreas con menor productividad.
                
                
                  Nuestro ejercicio prospectivo sugirió alteraciones en la dieta bajo los diferentes escenarios de cambio global futuro. Por primera vez, proporcionamos evidencia cuantitativa de cómo los patrones espacio‐temporales a gran escala en la presión pesquera y las condiciones ambientales pueden moldear la dieta del pez espada. Nuestro estudio destaca cómo la incorporación de interacciones tróficas en las proyecciones puede mejorar nuestra comprensión de las distribuciones futuras.},
	language = {en},
	number = {9},
	urldate = {2025-11-18},
	journal = {Journal of Animal Ecology},
	author = {Fernández‐Corredor, Elena and Fuster‐Alonso, Alba and Ramírez, Francisco and Giménez, Joan and García‐Barcelona, Salvador and Macías, David and Coll, Marta and Navarro, Joan},
	month = sep,
	year = {2025},
	pages = {1784--1799},
}

