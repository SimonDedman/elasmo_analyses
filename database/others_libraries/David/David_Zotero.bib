@article{gimenez_identification_2023-1,
	title = {Identification of priority cetacean areas in the north‐east {Atlantic} using systematic conservation planning},
	volume = {33},
	issn = {1052-7613, 1099-0755},
	url = {https://onlinelibrary.wiley.com/doi/10.1002/aqc.4015},
	doi = {10.1002/aqc.4015},
	abstract = {Abstract
            
              
                
                  Mobile marine protected areas have been proposed for the conservation of highly seasonal or mobile marine megafauna. However, seasonal data on the distribution of marine wildlife to inform protected areas are generally scarce worldwide, especially for cetaceans, which makes dynamic solutions difficult to implement.
                
                
                  Furthermore, conservation objectives are often set at the level of individual species rather than at the community level, despite many species having similar or overlapping habitat requirements, and a comparison of the effectiveness of mobile vs. static Marine Protected Areas options has rarely been done.
                
                
                  Systematic conservation planning was used to identify priority areas of cetacean biodiversity in the north‐east Atlantic accounting for seasonal changes in distribution. Consistent hotspots across seasons at a community level, in particular along the shelf edge, suggest that fixed priority areas for cetacean biodiversity may be appropriate.
                
                
                  The area required for protection to meet conservation targets (i.e. 20\% of a population occurring within a protected area) is minimized when considering populations at basin scale rather than national level. Highly mobile megafauna normally exploit persistent and predictable oceanographic features, so a habitat suitability rather than a jurisdiction‐based approach is more appropriate.},
	language = {en},
	number = {12},
	urldate = {2025-11-18},
	journal = {Aquatic Conservation: Marine and Freshwater Ecosystems},
	author = {Giménez, Joan and Waggitt, James J. and Jessopp, Mark},
	month = dec,
	year = {2023},
	pages = {1571--1579},
	file = {Texto completo:C\:\\Users\\david\\Zotero\\storage\\VF7QNJ5N\\Giménez et al. - 2023 - Identification of priority cetacean areas in the north‐east Atlantic using systematic conservation p.pdf:application/pdf},
}

