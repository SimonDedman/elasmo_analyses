	pages = {2087--2098},
	file = {Link et al. - 2023 - Why we need weather forecast analogues for marine .pdf:C\:\\Users\\elena\\Zotero\\storage\\XT28S8RC\\Link et al. - 2023 - Why we need weather forecast analogues for marine .pdf:application/pdf},
}

