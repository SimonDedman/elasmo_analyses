@article{landell-mills_how_nodate,
	title = {How swordfish swim faster than cheetahs run.},
	abstract = {The physics of how fish swim remains unexplained leading to continued mystery how swordfish can swim at 100 km/hr, outpacing a cheetah running on land at 90 km/hr. Grays paradox has also remained an enigma; how a dolphin can swim as fats as it does. Also, tuna swim almost as fast as a cheetah can run. See Fig. 1a. Despite extensive research and improved experimental technology, conventional physics has been unable to adequately explain these enigmas. The missing part of the solution is based on research into how frisbees generate lift according to Newtonian mechanics. In short, the solution is that swordfish produce minimal drag as they swim, due to the manner in which they push the water to generate motion.},
	language = {en},
