	month = nov,
	year = {2024},
	note = {Number: 1
Publisher: Nature Publishing Group},
	keywords = {Ecology, Behavioural ecology, Ecosystem ecology},
	pages = {29352},
	file = {Full Text PDF:C\:\\Users\\elena\\Zotero\\storage\\BW5QVLB9\\Rudd et al. - 2024 - High-resolution biologging of an Atlantic bluefin .pdf:application/pdf},
