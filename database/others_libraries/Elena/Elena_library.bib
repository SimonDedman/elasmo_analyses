@article{beltran_elephant_2025,
	title = {Elephant seals as ecosystem sentinels for the northeast {Pacific} {Ocean} twilight zone},
	volume = {387},
	issn = {0036-8075, 1095-9203},
	url = {https://www.science.org/doi/10.1126/science.adp2244},
	doi = {10.1126/science.adp2244},
	abstract = {The open ocean twilight zone holds most of the global fish biomass but is poorly understood owing to difficulties of measuring subsurface ecosystem processes at scale. We demonstrate that a wide-ranging carnivore—the northern elephant seal—can serve as an ecosystem sentinel for the twilight zone. We link ocean basin–scale foraging success with oceanographic indices to estimate twilight zone fish abundance five decades into the past, and into the future. We discovered that a small variation in maternal foraging success amplified into larger changes in offspring body mass and enormous variation in first-year survival and recruitment. Worsening oceanographic conditions could shift predator population trajectories from current growth to sharp declines. As ocean integrators, wide-ranging predators could reveal impacts of future anthropogenic change on open ocean ecosystems.
          , 
            Editor’s summary
            
              Most of the ocean fish biomass exists in the “twilight zone,” an important region of the open ocean that is notoriously difficult to sample and monitor. Beltran
              et al
              . tested whether an important predator in this ecosystem, the northern elephant seal, could be used as an indicator of fish abundance, and thus ecosystem health, in this zone. Using foraging patterns and success linked to ocean conditions, the authors were able to successfully hindcast twilight zone fish abundance. Such hindcasting success facilitated future predictions. Elephant seals can thus provide insight into how this hidden but essential system responds to external changes. —Sacha Vignieri},
	language = {en},
	number = {6735},
	urldate = {2025-08-05},
	journal = {Science},
	author = {Beltran, Roxanne S. and Payne, Allison R. and Kilpatrick, A. Marm and Hale, Conner M. and Reed, Madison and Hazen, Elliott L. and Bograd, Steven J. and Jouma’a, Joffrey and Robinson, Patrick W. and Houle, Emma and Matern, Wade and Sabah, Alea and Lewis, Kathryn and Sebandal, Samantha and Coughlin, Allison and Heredia, Natalia Valdes and Penny, Francesca and Dalrymple, Sophie Rose and Penny, Heather and Sherrier, Meghan and Peterson, Ben and Reiter, Joanne and Le Boeuf, Burney J. and Costa, Daniel P.},
	month = feb,
	year = {2025},
	pages = {764--769},
	file = {PDF:C\:\\Users\\elena\\Zotero\\storage\\QGKVZSXJ\\Beltran et al. - 2025 - Elephant seals as ecosystem sentinels for the northeast Pacific Ocean twilight zone.pdf:application/pdf},
}

