@article{romeo_evaluation_2009,
	title = {An evaluation of resource partitioning between two billfish, \textit{{Tetrapturus} belone} and \textit{{Xiphias} gladius} , in the central {Mediterranean} {Sea}},
	volume = {89},
	issn = {0025-3154, 1469-7769},
	url = {https://www.cambridge.org/core/product/identifier/S0025315408002087/type/journal_article},
	doi = {10.1017/S0025315408002087},
	abstract = {The present study attempts to give information on the resource partitioning between the Mediterranean spearﬁsh (Tetrapturus belone) and the swordﬁsh (Xiphias gladius). The contents of 53 T. belone and 95 X. gladius non-empty stomachs were analysed from specimens caught in the central Mediterranean Sea (Strait of Messina), from 2004 to 2006, by the harpoon ﬁshery. Daily catches (expressed as number of ﬁsh) showed the contemporary occurrence of both species in the studied area then allowing direct comparison of diets. Epipelagic ﬁsh were the dominant prey (\%IRI ¼ 99.1) of T. belone. Eight families were identiﬁed among them, with the dominance of Belonidae and Clupeidae, which represented 40.9\% and 36.8\%, respectively, of the total preyed items in terms of \%IRI and were mostly composed of Sardinella aurita and Belone belone. Xiphias gladius preyed mainly on teleosts and cephalopods, which represented 59\% and 39.1\%, respectively, of the total preyed items in terms of \%IRI. Eleven teleost and ﬁve cephalopod families were recognized among them with the dominance of Trichiuridae (IRI\% ¼ 30.5) and Ommastrephidae (IRI\% ¼ 27.6). The ﬁrst was represented only by Lepidopus caudatus (IRI\% ¼ 30.5), while the latter by the squid Todarodes sagittatus (IRI\% ¼ 21.1) and Illex coindettii (IRI\% ¼ 6.5). Results of a multivariate statistical analysis demonstrated that the dietary compositions differed signiﬁcantly between swordﬁsh and spearﬁsh. Diet overlap analysed with the Schoener and Horn indices showed low values (0.23 and 0.21 for the two indices) underlining a food partitioning that prevents competitive exclusion. Our results highlight a feeding strategy that is more related to the habitat of the species than to the food availability. In fact, migration patterns of the two predators are quite different. Swordﬁsh show vertical migrations from 0 to 800 m while spearﬁsh are characterized by limited migrations, ranging between 0 and 200 m depths. The observation of speciﬁc prey items in the stomach content of both billﬁsh conﬁrmed the bathymetric range of their migrations.},
	language = {en},
	number = {4},
	urldate = {2022-07-15},
	journal = {Journal of the Marine Biological Association of the United Kingdom},
	author = {Romeo, Teresa and Consoli, Pierpaolo and Castriota, Luca and Andaloro, Franco},
	month = jun,
	year = {2009},
	note = {Number: 4},
	keywords = {Mediterráneo, Mediterranean Sea, diet, Xiphias, Tetrapturus, Strait of Messina},
	pages = {849--857},
	file = {Romeo et al. - 2009 - An evaluation of resource partitioning between two.pdf:C\:\\Users\\elena\\Zotero\\storage\\DC93DFEP\\Romeo et al. - 2009 - An evaluation of resource partitioning between two.pdf:application/pdf},
}

@article{romeo_pelagic_2011,
	title = {Pelagic cephalopods of the central {Mediterranean} {Sea} determined by the analysis of the stomach content of large fish predators},
