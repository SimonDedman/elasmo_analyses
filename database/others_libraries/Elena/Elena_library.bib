	author = {Biton-Porsmoguer, Sebastián and Bănaru, Daniela and Harmelin-Vivien, Mireille and Béarez, Philippe and Bouchoucha, Marc and Marco-Miralles, Françoise and Marquès, Montse and Lloret, Josep},
