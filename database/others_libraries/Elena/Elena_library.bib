@article{braccini_spatial_2021,
	title = {Spatial and temporal patterns in catch rates from multispecies shark fisheries in {Western} {Australia}},
	volume = {213},
	issn = {0964-5691},
	url = {https://www.sciencedirect.com/science/article/pii/S0964569121003665},
	doi = {10.1016/j.ocecoaman.2021.105883},
	abstract = {Time series of commercial catch rates are the most commonly available proxy for shark abundance trends. Biased interpretations of spatial and temporal patterns in commercial catch rates have led to misleading stock status assessments. In this study, we outlined the steps required to account for unbalanced fishery data sets and derive standardised catch rates for the main commercial species taken in the shark fisheries of Western Australia (WA) as a case study. Catch rates peaked early in the year for sandbar (March) and dusky (March–April) sharks but towards the end of the year (September–November) for whiskery sharks. For gummy sharks, catch rates fluctuated throughout the year. Catch rates increased with depth for whiskery and sandbar sharks but decreased with depth for dusky sharks. Spatial hotspots occurred in the southwest and east of 123° E for whiskery sharks, east of 124° for gummy sharks, in the southwest for dusky sharks, and in the west coast between 28° and 30° S for sandbar sharks. Following an initial decline, annual catch rates stabilized in recent years across all species. Our study illustrated the challenges associated with multispecies fisheries data for informing management and conservation, identified spatial hotspots and provided standardised catch rates for use in stock assessments. Given the lower economic value of sharks, fishery-independent surveying is unlikely to be achievable for most species. Hence, applying best practices for standardising available shark fishery-dependent data and communicating the corresponding uncertainty is essential for quantitative assessments.},
	urldate = {2024-02-26},
	journal = {Ocean \& Coastal Management},
	author = {Braccini, Matias and Denham, Ainslie and O'Neill, Michael F. and Lai, Eva},
	month = nov,
	year = {2021},
	keywords = {Australia, Elasmobranchs, Generalized additive model, Non-linear relation},
	pages = {105883},
	file = {Braccini et al. - 2021 - Spatial and temporal patterns in catch rates from .pdf:C\:\\Users\\elena\\Zotero\\storage\\B35XQ7F2\\Braccini et al. - 2021 - Spatial and temporal patterns in catch rates from .pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\elena\\Zotero\\storage\\8U4QS7HN\\S0964569121003665.html:text/html},
}

