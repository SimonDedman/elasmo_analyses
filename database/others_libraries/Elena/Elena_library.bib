	pages = {1--8},
	file = {ScienceDirect Full Text PDF:C\:\\Users\\elena\\Zotero\\storage\\GBF9SLRV\\Hobday et al. - 2015 - Impacts of climate change on marine top predators.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\elena\\Zotero\\storage\\S7J5UVAV\\S0967064515000247.html:text/html},
