	keywords = {Animals, Fishes, Climate Change, global warming, Physiology, aerobic metabolism, Aerobiosis, EPOC, excess post-exercise oxygen consumption, oxygen consumption rate, oxygen uptake, oxygen- and capacity-limited thermal tolerance, Respiration, specific dynamic action},
