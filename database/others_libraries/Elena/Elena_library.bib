	month = jul,
	year = {2015},
	note = {Number: 1
Publisher: Nature Publishing Group},
	keywords = {Marine biology, Climate change, Biooceanography},
	pages = {7615},
	file = {Full Text PDF:C\:\\Users\\elena\\Zotero\\storage\\W6RHDR87\\Halpern et al. - 2015 - Spatial and temporal changes in cumulative human i.pdf:application/pdf},
}

@article{ramirez_spatial_2018,
	title = {Spatial congruence between multiple stressors in the {Mediterranean} {Sea} may reduce its resilience to climate impacts},
