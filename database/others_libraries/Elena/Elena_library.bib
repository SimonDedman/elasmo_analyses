@article{darling_social-environmental_2019,
	title = {Social-environmental drivers inform strategic management of coral reefs in the {Anthropocene}},
	volume = {3},
	issn = {2397-334X},
	doi = {10.1038/s41559-019-0953-8},
	abstract = {Without drastic efforts to reduce carbon emissions and mitigate globalized stressors, tropical coral reefs are in jeopardy. Strategic conservation and management requires identification of the environmental and socioeconomic factors driving the persistence of scleractinian coral assemblages-the foundation species of coral reef ecosystems. Here, we compiled coral abundance data from 2,584 Indo-Pacific reefs to evaluate the influence of 21 climate, social and environmental drivers on the ecology of reef coral assemblages. Higher abundances of framework-building corals were typically associated with: weaker thermal disturbances and longer intervals for potential recovery; slower human population growth; reduced access by human settlements and markets; and less nearby agriculture. We therefore propose a framework of three management strategies (protect, recover or transform) by considering: (1) if reefs were above or below a proposed threshold of {\textgreater}10\% cover of the coral taxa important for structural complexity and carbonate production; and (2) reef exposure to severe thermal stress during the 2014-2017 global coral bleaching event. Our findings can guide urgent management efforts for coral reefs, by identifying key threats across multiple scales and strategic policy priorities that might sustain a network of functioning reefs in the Indo-Pacific to avoid ecosystem collapse.},
	language = {eng},
	number = {9},
	journal = {Nature Ecology \& Evolution},
	author = {Darling, Emily S. and McClanahan, Tim R. and Maina, Joseph and Gurney, Georgina G. and Graham, Nicholas A. J. and Januchowski-Hartley, Fraser and Cinner, Joshua E. and Mora, Camilo and Hicks, Christina C. and Maire, Eva and Puotinen, Marji and Skirving, William J. and Adjeroud, Mehdi and Ahmadia, Gabby and Arthur, Rohan and Bauman, Andrew G. and Beger, Maria and Berumen, Michael L. and Bigot, Lionel and Bouwmeester, Jessica and Brenier, Ambroise and Bridge, Tom C. L. and Brown, Eric and Campbell, Stuart J. and Cannon, Sara and Cauvin, Bruce and Chen, Chaolun Allen and Claudet, Joachim and Denis, Vianney and Donner, Simon and Estradivari, null and Fadli, Nur and Feary, David A. and Fenner, Douglas and Fox, Helen and Franklin, Erik C. and Friedlander, Alan and Gilmour, James and Goiran, Claire and Guest, James and Hobbs, Jean-Paul A. and Hoey, Andrew S. and Houk, Peter and Johnson, Steven and Jupiter, Stacy D. and Kayal, Mohsen and Kuo, Chao-Yang and Lamb, Joleah and Lee, Michelle A. C. and Low, Jeffrey and Muthiga, Nyawira and Muttaqin, Efin and Nand, Yashika and Nash, Kirsty L. and Nedlic, Osamu and Pandolfi, John M. and Pardede, Shinta and Patankar, Vardhan and Penin, Lucie and Ribas-Deulofeu, Lauriane and Richards, Zoe and Roberts, T. Edward and Rodgers, Ku'ulei S. and Safuan, Che Din Mohd and Sala, Enric and Shedrawi, George and Sin, Tsai Min and Smallhorn-West, Patrick and Smith, Jennifer E. and Sommer, Brigitte and Steinberg, Peter D. and Sutthacheep, Makamas and Tan, Chun Hong James and Williams, Gareth J. and Wilson, Shaun and Yeemin, Thamasak and Bruno, John F. and Fortin, Marie-Josée and Krkosek, Martin and Mouillot, David},
	month = sep,
