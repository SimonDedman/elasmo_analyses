	title = {Climate-driven global redistribution of an ocean giant predicts increased threat from shipping},
	copyright = {2024 The Author(s)},
	issn = {1758-6798},
	url = {https://www.nature.com/articles/s41558-024-02129-5},
	doi = {10.1038/s41558-024-02129-5},
	abstract = {Climate change is shifting animal distributions. However, the extent to which future global habitats of threatened marine megafauna will overlap existing human threats remains unresolved. Here we use global climate models and habitat suitability estimated from long-term satellite-tracking data of the world’s largest fish, the whale shark, to show that redistributions of present-day habitats are projected to increase the species’ co-occurrence with global shipping. Our model projects core habitat area losses of {\textgreater}50\% within some national waters by 2100, with geographic shifts of over 1,000 km (∼12 km yr−1). Greater habitat suitability is predicted in current range-edge areas, increasing the co-occurrence of sharks with large ships. This future increase was ∼15,000 times greater under high emissions compared with a sustainable development scenario. Results demonstrate that climate-induced global species redistributions that increase exposure to direct sources of mortality are possible, emphasizing the need for quantitative climate-threat predictions in conservation assessments of endangered marine megafauna.},
	language = {en},
	urldate = {2024-10-08},
	journal = {Nature Climate Change},
	author = {Womersley, Freya C. and Sousa, Lara L. and Humphries, Nicolas E. and Abrantes, Kátya and Araujo, Gonzalo and Bach, Steffen S. and Barnett, Adam and Berumen, Michael L. and Lion, Sandra Bessudo and Braun, Camrin D. and Clingham, Elizabeth and Cochran, Jesse E. M. and de la Parra, Rafael and Diamant, Stella and Dove, Alistair D. M. and Duarte, Carlos M. and Dudgeon, Christine L. and Erdmann, Mark V. and Espinoza, Eduardo and Ferreira, Luciana C. and Fitzpatrick, Richard and Cano, Jaime González and Green, Jonathan R. and Guzman, Hector M. and Hardenstine, Royale and Hasan, Abdi and Hazin, Fábio H. V. and Hearn, Alex R. and Hueter, Robert E. and Jaidah, Mohammed Y. and Labaja, Jessica and Ladino, Felipe and Macena, Bruno C. L. and Meekan, Mark G. and Morris, John J. and Norman, Bradley M. and Peñaherrera-Palma, Cesar R. and Pierce, Simon J. and Quintero, Lina Maria and Ramírez-Macías, Dení and Reynolds, Samantha D. and Robinson, David P. and Rohner, Christoph A. and Rowat, David R. L. and Sequeira, Ana M. M. and Sheaves, Marcus and Shivji, Mahmood S. and Sianipar, Abraham B. and Skomal, Gregory B. and Soler, German and Syakurachman, Ismail and Thorrold, Simon R. and Thums, Michele and Tyminski, John P. and Webb, D. Harry and Wetherbee, Bradley M. and Queiroz, Nuno and Sims, David W.},
	month = oct,
	year = {2024},
	note = {Publisher: Nature Publishing Group},
	keywords = {Climate-change ecology, Conservation biology, Climate-change impacts},
	pages = {1--10},
	file = {Full Text PDF:C\:\\Users\\elena\\Zotero\\storage\\53EDIIFX\\Womersley et al. - 2024 - Climate-driven global redistribution of an ocean g.pdf:application/pdf},
