@article{riesgo_understanding_nodate,
	title = {Understanding the relative importance of sex, body size, trophic niche, and geographical location in the mercury concentrations of the blue shark},
	abstract = {Since the middle nineties, anthropogenic activities have increased environmental concentrations of heavy metals in marine ecosystems. Given their high toxicity and persistence, these pollutants cause harmful effects on marine organisms. Top marine predators are particularly susceptible to bioaccumulation and biomagnification of pollutants through the food webs, and thus, these species are described as good sentinels for monitoring metal accumulation such mercury (Hg) in marine ecosystems. However, to be used as sentinels, it is important to understand the main ecological factors affecting the concentrations of pollutants in these marine organisms. In the present study, , our main objective was to investigate the effect of body size, sex, trophic niche (inferred by stable isotopic values) and geographic area on Hg concentrations of a large top pelagic predator, the blue shark (Prionace glauca). For this, we analysed Hg in muscle samples from male and female blue sharks of different body sizes collected from the waters surrounding the Canary Islands and the South of Portugal, in the Atlantic Ocean, to the north-western Mediterranean Sea. The results revealed that geographical area of sampling was an important factor explaining Hg concentrations, showing the higher values in the Mediterranean blue sharks. These geographical differences reflect the knowing presence of higher levels of Hg pollution in the Mediterranean Sea in comparison with the Atlantic Ocean. We also found a positive relationship between Hg concentrations and body size of blue sharks. The higher Hg values in the larger individuals indicates a bioaccumulation process of this pollutant in relation with body length. Although we did not find a relationship between Hg and δ15N values (trophic level), we found a relationship between Hg concentration and δ13C values, a proxy of the use of inshore-offshore marine habitats. Specifically, individuals with depleted δ13C values that potentially foraged in offshore waters showed high Hg values. Finally, it is important to remark that most of the analysed blue sharks showed mercury values that exceeded the legal limit of 1 mg/kg wet weight established by the European Union for human consumption.},
	language = {en},
	author = {Riesgo, María Dolores and Navarro, Joan},
	pages = {34},
	file = {Torres - Understanding the relative importance of sex, body.pdf:C\:\\Users\\elena\\Zotero\\storage\\E447QIAZ\\Torres - Understanding the relative importance of sex, body.pdf:application/pdf},
}

