@article{kamel-moutalibi_diet_nodate,
	title = {Diet of common torpedo {Torpedo} torpedo ({Chondrichthyes}: {Torpedinidae}) from the {Lagoon} of {Bizerte} (northeastern {Tunisia}, central {Mediterranean})},
	abstract = {Diet of common torpedo, Torpedo torpedo (Linnaeus, 1758) was studied in relation to sex, size and seasons from specimens collected in the Lagoon of Bizerte, a brackish area located in northeastern Tunisia (central Mediterranean). Of the 565 stomach contents examined between May 2010 and April 2011, 425 were empty, with vacuity index (VI) = 75.22\%, percentage that significantly changed with sex. Only fourteen different taxa were recorded: 7 were osteichthyans, while crustaceans, annelids, cephalopods, and gasteropods were only represented each one by a single taxon. The dominant preys were osteichthyans, with \%IRI = 41.74, among them gobiids were mainly found, as a consequence of feeding strategies observed in common torpedos. The trophic level (Troph) of 3.78 calculated for T. torpedo was high and pointed out that the species is a top carnivorous predator; additionally, no significant changes were recorded in Troph values related to sex, size and seasons.},
	language = {en},
	author = {Kamel-Moutalibi, Olfa EL and Mnasri, Néjia and Boumaïza, Moncef and Reynaud, Christian and Capapé, Christian},
	file = {PDF:C\:\\Users\\elena\\Zotero\\storage\\VBPM7MAU\\Kamel-Moutalibi et al. - Diet of common torpedo Torpedo torpedo (Chondrichthyes Torpedinidae) from the Lagoon of Bizerte (no.pdf:application/pdf},
}

