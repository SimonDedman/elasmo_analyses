	author = {Damalas, D. and Megalofonou, P. and Apostolopoulou, M.},
	year = {2007},
	note = {Number: 2},
	keywords = {Swordfish, CPUE, Bathymetry, Generalized additive models, Longline, Lunar index, SST},
	pages = {233--246},
	file = {Damalas et al. - 2007 - Environmental, spatial, temporal and operational e.pdf:C\:\\Users\\elena\\Zotero\\storage\\WQ8JIAI8\\Damalas et al. - 2007 - Environmental, spatial, temporal and operational e.pdf:application/pdf;Snapshot:C\:\\Users\\elena\\Zotero\\storage\\KEU275SP\\display.html:text/html},
