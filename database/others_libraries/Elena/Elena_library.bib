Publisher: Nature Publishing Group},
	keywords = {Marine biology, Conservation biology},
	pages = {1--9},
	file = {Full Text PDF:C\:\\Users\\elena\\Zotero\\storage\\8TTMN2AA\\Fernandes et al. - 2017 - Coherent assessments of Europe’s marine fishes sho.pdf:application/pdf},
