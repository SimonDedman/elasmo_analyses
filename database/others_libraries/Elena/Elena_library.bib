@article{lin_ocean_2023,
	title = {Ocean temperature drove changes in the mesopelagic fish community at the edge of the {Pacific} {Warm} {Pool} over the past 460,000 years},
	volume = {9},
	issn = {2375-2548},
	url = {https://www.science.org/doi/10.1126/sciadv.adf0656},
	doi = {10.1126/sciadv.adf0656},
	abstract = {Field observations and theoretical modeling suggest that ongoing anthropogenic ocean warming will lead to marine ecosystem degradation. Mesopelagic fish are a fundamental component of the pelagic ecosystem, and their role in linking the surface- and deep-ocean ecosystems is essential for the biological carbon pump. However, their response to a warmer ocean is unconstrained because of data scarcity. Using extraordinarily well-preserved fish otoliths, we reconstruct a continuous mesopelagic fish community record in the Pacific Warm Pool region over 460,000 years. Fish production and diversity followed hump-shaped temperature gradients, with lower tipping point temperatures for the diversity than the production by {\textasciitilde}1.5° to 2.0°C. During warmer-than-present interglacial periods, both production and diversity declined drastically. Our findings imply that the temperature-sensitive mesopelagic fish community at the southwestern margin of the Pacific Warm Pool, and possibly other hydrographically similar regions, may be especially affected if ocean warming continues unabated in the future.
          , 
            Deep-sea fossils reveal cyclic fluctuations in fish community structure over four glacial cycles.},
	language = {en},
	number = {27},
	urldate = {2025-08-05},
	journal = {Science Advances},
	author = {Lin, Chien-Hsiang and Wei, Chih-Lin and Ho, Sze Ling and Lo, Li},
	month = jul,
	year = {2023},
	pages = {eadf0656},
	file = {PDF:C\:\\Users\\elena\\Zotero\\storage\\GVEHVN48\\Lin et al. - 2023 - Ocean temperature drove changes in the mesopelagic fish community at the edge of the Pacific Warm Po.pdf:application/pdf},
}

