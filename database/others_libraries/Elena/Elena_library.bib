@article{rowland_assessing_2023,
	title = {Assessing risk of ecosystem collapse in a changing climate},
	url = {https://ecoevorxiv.org/repository/view/5753/},
	doi = {10.32942/X2HS4Q},
	abstract = {Climate change has pervasive impacts on Earth’s ecosystems, but the diversity and complexity of ecosystems makes estimating the severity of impacts and the resulting risk of collapse difficult. In this perspective, we conceptualise the challenge of understanding how climate change alters ecosystems, and how to reliably measure those changes in ecosystem risk assessments, focussing on the IUCN Red List of Ecosystems. We propose solutions to resolve these challenges – using diverse teams, conceptual models, diverse using data sources including projections, learning from analogous ecosystems, and evaluating uncertainties – and we identify research gaps to bridge these challenges. Together, these solutions will improve our capacity to produce reliable assessments of collapse risk under climate change to inform timely and effective ecosystem conservation.},
	language = {en},
	urldate = {2025-08-05},
	journal = {Nature Climate Change},
	author = {Rowland, Jessica and Nicholson, Emily and Ferrer-Paris, Jose-Rafael and Keith, David and Murray, Nicholas and Sato, Chloe and Toth, Aniko and Tolsma, Arn and Venn, Susanna and Asmüssen, Marianne and Pliscoff, Patricio and Zambrana-Torrelio, Carlos and Lester, Rebecca and Regan, Tracey},
