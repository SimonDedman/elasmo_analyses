	file = {Edelist - 2014 - New length-weight relationships and L maxsu.pdf:C\:\\Users\\elena\\Zotero\\storage\\I5FF4GG7\\Edelist - 2014 - New length-weight relationships and L maxsu.pdf:application/pdf},
}

