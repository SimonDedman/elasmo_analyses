@article{sardenne_trophic_2016,
	title = {Trophic niches of sympatric tropical tuna in the {Western} {Indian} {Ocean} inferred by stable isotopes and neutral fatty acids},
	volume = {146},
	issn = {00796611},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0079661115300641},
	doi = {10.1016/j.pocean.2016.06.001},
	abstract = {This study examined the trophic ecology of three sympatric tropical tuna species (bigeye BET, skipjack SKJ, and yellowﬁn YFT) sampled in the Western Indian Ocean throughout 2013. Speciﬁcally we explored inter-speciﬁc resource partitioning and ontogenetic variability using neutral fatty acids and stable isotope analysis of liver and muscle from small (6100 cm fork length, FL) and large ({\textgreater}100 cm FL) tuna collected in mixed schools at the surface by purse-seine. Both biochemical tracers were used to calculate trophic niche indices that collectively revealed high potential for resource overlap, especially among small tuna. Resource overlap appeared strongest between BET and YFT, with SKJ tissues having high carbon isotope (d13C) values (À17 ± 0.3‰), lower nitrogen isotope (d15N) values (11.4 ± 0.6‰), and higher relative proportion of poly-unsaturated fatty acids (PUFA) than the two other species, indicating a different diet. Size was found to be a strong predictor for most biochemical tracers in the three species with d13C, d15N and total lipid content in the liver. In the larger species (YFT and BET), proportions of mono-unsaturated fatty acids typically increased with size, while quantities of PUFA decreased. In addition to ontogenetic variability, trophic markers were shown to vary between sampling area and season: higher lipid reserves and d15N values, and lower d13C values occurred during monsoon periods around Seychelles than in the Mozambique Channel (parted from about 1500 km). Our multi-tracer approach reveals the magnitude of potential competitive interactions in mixed tropical tuna schools at both small and large sizes and demonstrates that ontogenetic niche differentiation acts as a major factor of coexistence in tropical tuna.},
	language = {en},
	urldate = {2022-07-15},
	journal = {Progress in Oceanography},
	author = {Sardenne, Fany and Bodin, Nathalie and Chassot, Emmanuel and Amiel, Aurélien and Fouché, Edwin and Degroote, Maxime and Hollanda, Stéphanie and Pethybridge, Heidi and Lebreton, Benoit and Guillou, Gaël and Ménard, Frédéric},
	month = aug,
	year = {2016},
	pages = {75--88},
	file = {Sardenne et al. - 2016 - Trophic niches of sympatric tropical tuna in the W.pdf:C\:\\Users\\elena\\Zotero\\storage\\4RS3M6BZ\\Sardenne et al. - 2016 - Trophic niches of sympatric tropical tuna in the W.pdf:application/pdf},
}

