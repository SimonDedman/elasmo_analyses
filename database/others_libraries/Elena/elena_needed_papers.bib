	url = {https://aiep.pensoft.net/article/26416/},
	doi = {10.3750/AIP2013.43.4.11},
	abstract = {The capture of a juvenile, male, great white shark, Carcharodon carcharias (Linnaeus, 1758), off the Corsican coast (Mediterranean Sea) in 2012 is reported in this note along with two other new records (1976 and 2011). Additionally, 8 other historical and more recent records from the same area are presented and commented. These records are compared with those reported from more distant areas. Conclusions drawn based on the presently analysed material indicate that a sustainable and isolated C. carcharias population has probably established in the Mediterranean Sea, although more new records are needed to confirm this hypothesis.},
