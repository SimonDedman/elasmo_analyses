Publisher: American Association for the Advancement of Science},
	pages = {225--230},
	file = {Full Text PDF:C\:\\Users\\elena\\Zotero\\storage\\G7D6GB3F\\Worm et al. - 2024 - Global shark fishing mortality still rising despit.pdf:application/pdf},
}
}

